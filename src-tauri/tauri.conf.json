{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RogueAudio",
  "version": "0.1.0",
  "identifier": "app.rogueaudio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "RogueAudio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:* https: http: ws: wss:; img-src 'self' asset: http://asset.localhost https: http: data: blob:; media-src 'self' asset: http://asset.localhost http://127.0.0.1:* http://localhost:* https: http: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.local/share/rogue-audio/downloads/**",
          "$HOME/.local/share/rogue-audio/covers/**",
          "$APPDATA/rogue-audio/downloads/**",
          "$APPDATA/rogue-audio/covers/**",
          "$LOCALDATA/rogue-audio/downloads/**",
          "$LOCALDATA/rogue-audio/covers/**",
          "$DATA/rogue-audio/downloads/**",
          "$DATA/rogue-audio/covers/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
